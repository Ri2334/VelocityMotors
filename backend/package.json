    "mongoose": "^8.3.1"
  },
  "devDependencies": {
    "cross-env": "^7.0.3",
    "jest": "^29.7.0",
    "mongodb-memory-server": "^9.1.8",
    "nodemon": "^3.1.0",
    "supertest": "^6.3.4"
  },
  "jest": {
